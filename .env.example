# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Truth Social credentials (required for truthbrush)
TRUTHSOCIAL_USERNAME=your_truth_social_username
TRUTHSOCIAL_PASSWORD=your_truth_social_password

# LLM API keys (set whichever provider you use)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Alpaca — required for 1-minute historical data (SPY/QQQ) AND live trading
# Free account at https://alpaca.markets — paper trading keys work for data access
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: market data provider key (for future Polygon/Massive swap)
POLYGON_API_KEY=
